{
    "info": {
        "name": "Interfaces-3 CRUD Collection",
        "description": "Coleccion para probar CRUD (4 operaciones) de users, roles y games.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000"
        },
        {
            "key": "userId",
            "value": "1"
        },
        {
            "key": "roleId",
            "value": "1"
        },
        {
            "key": "gameId",
            "value": "1"
        }
    ],
    "item": [
        {
            "name": "Users",
            "item": [
                {
                    "name": "Create User",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"passwordHash\": \"hash123\",\n  \"bio\": \"Board game enthusiast\",\n  \"roleName\": \"admin\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/users",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/users",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    }
                },
                {
                    "name": "Update User",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"john_updated\",\n  \"email\": \"john.updated@example.com\",\n  \"bio\": \"Updated profile\",\n  \"roleName\": \"user\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/users/{{userId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "{{userId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete User",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/users/{{userId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "users",
                                "{{userId}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Roles",
            "item": [
                {
                    "name": "Create Role",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"moderator\",\n  \"description\": \"Role for moderation tasks\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/roles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "roles"
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Roles",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/roles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "roles"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Role",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"moderator_updated\",\n  \"description\": \"Updated description\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/roles/{{roleId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "roles",
                                "{{roleId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Role",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/roles/{{roleId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "roles",
                                "{{roleId}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Games",
            "item": [
                {
                    "name": "Create Game",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Catan\",\n  \"description\": \"Trade and build strategy board game\",\n  \"minPlayers\": 3,\n  \"maxPlayers\": 4,\n  \"category\": \"strategy\",\n  \"createdBy\": 1\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/games",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "games"
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Games",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/games",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "games"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Game",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"description\": \"Updated strategy game description\",\n  \"maxPlayers\": 5,\n  \"category\": \"board\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/games/{{gameId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "games",
                                "{{gameId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Game",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/games/{{gameId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "games",
                                "{{gameId}}"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}